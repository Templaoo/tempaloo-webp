      }
    },

    {
      "id": "word-fade-up",
      "label": "Mots — fade up",
      "category": "text",
      "description": "Chaque mot animé séparément (translateY + fade). Standard pour headlines.",
      "requires": ["ScrollTrigger", "SplitText"],
      "splits": "words",
      "params": {
        "duration":     { "type": "number", "value": 0.6,  "min": 0.2, "max": 1.5, "step": 0.05, "unit": "s", "label": "Durée par mot" },
        "ease":         { "type": "enum",   "value": "power3.out", "enum": "EASE", "label": "Ease" },
        "stagger":      { "type": "number", "value": 0.04, "min": 0.01, "max": 0.2, "step": 0.005, "unit": "s", "label": "Stagger" },
        "staggerFrom":  { "type": "enum",   "value": "start", "enum": "STAGGER_FROM", "label": "Stagger from" },
        "y":            { "type": "number", "value": 16,   "min": 0,    "max": 60, "step": 2, "unit": "px", "label": "Distance Y" }
      },
      "scrollTrigger": {
        "start": { "type": "enum", "value": "top 85%", "enum": "TRIGGER_START", "label": "Start" },
        "toggleActions": { "type": "enum", "value": "play none none reverse", "enum": "TOGGLE_ACTIONS", "label": "Toggle actions" }
      }
    },

    {
      "id": "word-fade-blur",
      "label": "Mots — fade + blur (premium)",
      "category": "text",
      "description": "Chaque mot révélé avec flou décroissant. Effet éditorial / luxe.",
