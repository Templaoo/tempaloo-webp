        "stagger":   { "type": "number", "value": 0.04, "min": 0.01, "max": 0.2, "step": 0.005, "unit": "s", "label": "Stagger" },
        "staggerFrom": { "type": "enum", "value": "start", "enum": "STAGGER_FROM", "label": "Stagger from" },
        "blurFrom":  { "type": "number", "value": 8,   "min": 0,    "max": 24, "step": 1, "unit": "px", "label": "Flou de départ" }
      },
      "scrollTrigger": {
        "start": { "type": "enum", "value": "top 85%", "enum": "TRIGGER_START", "label": "Start" },
        "toggleActions": { "type": "enum", "value": "play none none reverse", "enum": "TOGGLE_ACTIONS", "label": "Toggle actions" }
      }
    },

    {
      "id": "word-slide-up-overflow",
      "label": "Mots — slide up (cinematic)",
      "category": "text",
      "description": "Mots montent depuis sous un masque. Style Stripe / Linear.",
      "requires": ["ScrollTrigger", "SplitText"],
      "splits": "words",
      "params": {
        "duration":  { "type": "number", "value": 0.7,  "min": 0.2, "max": 1.5, "step": 0.05, "unit": "s", "label": "Durée" },
        "ease":      { "type": "enum",   "value": "power4.out", "enum": "EASE", "label": "Ease" },
