    {
      "id": "scroll-words-fill",
      "label": "Texte — scroll-linked words fill",
      "category": "text",
      "description": "Mots se remplissent au fil du scroll (scrub 1:1). Style Apple/Stripe-Tax. Trigger NON applicable — scrub.",
      "requires": ["ScrollTrigger", "SplitText"],
      "splits": "words",
      "scrubOnly": true,
      "params": {
        "stagger":      { "type": "number", "value": 0.1,  "min": 0.02, "max": 0.5, "step": 0.02, "unit": "s", "label": "Stagger" },
        "opacityFrom":  { "type": "number", "value": 0.18, "min": 0,    "max": 0.6, "step": 0.02, "unit": "", "label": "Opacité initiale" }
      },
      "scrollTrigger": {
        "start": { "type": "enum",   "value": "top 80%", "enum": "TRIGGER_START", "label": "Start" },
        "end":   { "type": "string", "value": "top 30%", "label": "End" },
        "scrub": { "type": "boolean", "value": true,    "locked": true, "label": "Scrub (lié au scroll)" }
      }
    },

