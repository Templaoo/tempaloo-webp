{
  "version": "2.0.0",
  "comment": "Single source of truth for animation presets. Read by PHP (Animation_Presets), runtime JS (animations.js), and React admin (AnimationPage). Adding a preset here = automatic exposure across all 3 layers. Each preset documents the EXACT GSAP parameters required by its skill file (gsap-core / gsap-timeline / gsap-scrolltrigger / gsap-plugins) — UI controls are auto-generated from the `params` schema; impossible to invent a knob GSAP doesn't support.",

  "enums": {
    "EASE": [
      { "id": "none",                  "label": "None (linear)" },
      { "id": "power1.out",            "label": "Power 1 — out (gentle)" },
      { "id": "power2.out",            "label": "Power 2 — out" },
      { "id": "power3.out",            "label": "Power 3 — out (default)" },
      { "id": "power4.out",            "label": "Power 4 — out (snappy)" },
      { "id": "power2.inOut",          "label": "Power 2 — in/out" },
      { "id": "power3.inOut",          "label": "Power 3 — in/out" },
      { "id": "expo.out",              "label": "Expo — out (cinematic)" },
      { "id": "circ.inOut",            "label": "Circ — in/out" },
      { "id": "back.out(1.7)",         "label": "Back — out (overshoot)" },
      { "id": "back.out(2.5)",         "label": "Back — out (strong overshoot)" },
      { "id": "elastic.out(1, 0.3)",   "label": "Elastic — out" },
      { "id": "bounce.out",            "label": "Bounce — out" },
      { "id": "sine.inOut",            "label": "Sine — in/out (smooth)" }
    ],
    "TRIGGER_START": [
      { "id": "top 90%",    "label": "Très tôt (90%)" },
      { "id": "top 85%",    "label": "Tôt (85%, défaut)" },
      { "id": "top 75%",    "label": "Standard (75%)" },
      { "id": "top 60%",    "label": "Tard (60%)" },
      { "id": "center 75%", "label": "Centré (75%)" },
      { "id": "center center", "label": "Centre écran" },
      { "id": "none",       "label": "Au chargement (sans scroll)" }
    ],
    "TOGGLE_ACTIONS": [
      { "id": "play none none none",     "label": "Une fois (forward seul)" },
      { "id": "play none none reset",    "label": "Replay (rewind à la sortie)" },
      { "id": "play none none reverse",  "label": "Bidirectionnel (défaut)" },
      { "id": "play pause resume reset", "label": "Pause hors écran" }
    ],
    "STAGGER_FROM": [
      { "id": "start",  "label": "Du début" },
      { "id": "end",    "label": "De la fin" },
      { "id": "center", "label": "Du centre" },
      { "id": "edges",  "label": "Des bords" },
      { "id": "random", "label": "Aléatoire" }
    ]
  },

  "elementTypes": [
    {
      "id": "h1",
      "label": "H1 — Titre principal",
      "icon": "type",
      "selectors": ["h1", ".elementor-widget-heading h1", ".elementor-heading-title h1"],
      "recommendedPreset": "word-fade-blur"
    },
    {
      "id": "h2",
      "label": "H2 — Titre de section",
      "icon": "type",
      "selectors": ["h2", ".elementor-widget-heading h2", ".elementor-heading-title h2"],
      "recommendedPreset": "word-fade-up"
    },
    {
      "id": "h3",
      "label": "H3 — Sous-titre",
      "icon": "type",
      "selectors": ["h3", ".elementor-widget-heading h3", ".elementor-heading-title h3"],
      "recommendedPreset": "fade-up"
    },
    {
      "id": "p",
      "label": "Paragraphe",
      "icon": "align-left",
      "selectors": ["p", ".elementor-widget-text-editor p"],
      "recommendedPreset": "fade-up"
    },
    {
      "id": "img",
      "label": "Image",
      "icon": "image",
      "selectors": ["img:not([data-tw-anim-skip])", ".elementor-widget-image img"],
      "recommendedPreset": "scale-in"
    },
    {
      "id": "button",
      "label": "Bouton / CTA",
      "icon": "mouse-pointer",
      "selectors": [".tw-btn", ".elementor-button", "button.cta"],
      "recommendedPreset": "fade-up"
    },
    {
      "id": "container",
      "label": "Container / Section",
      "icon": "square",
      "selectors": ["section[data-tw-anim-scope]", ".elementor-section", ".e-con.e-flex"],
      "recommendedPreset": "fade-up"
    },
    {
      "id": "link",
      "label": "Lien (texte)",
      "icon": "link",
      "selectors": ["a:not(.tw-btn):not(.elementor-button)"],
      "recommendedPreset": "fade"
    }
  ],

  "presets": [
    {
      "id": "none",
      "label": "Aucune",
      "category": "element",
      "description": "L'élément est rendu instantanément, sans animation. Utile pour désactiver un type ciblé.",
      "requires": [],
      "params": {},
      "scrollTrigger": null
    },

    {
      "id": "fade",
      "label": "Fade",
      "category": "element",
      "description": "Apparition par variation d'opacité uniquement. Discret, 100% accessible.",
      "requires": ["ScrollTrigger"],
      "params": {
        "duration": { "type": "number", "value": 0.45, "min": 0.1, "max": 2,    "step": 0.05, "unit": "s",  "label": "Durée" },
        "ease":     { "type": "enum",   "value": "power1.out", "enum": "EASE",  "label": "Ease" },
        "stagger":  { "type": "number", "value": 0,    "min": 0,   "max": 0.3, "step": 0.01, "unit": "s",  "label": "Stagger" },
        "useAutoAlpha": { "type": "boolean", "value": true, "label": "autoAlpha (visibility:hidden à 0)", "tip": "Recommandation gsap-core : évite les clics sur invisible." }
      },
      "scrollTrigger": {
        "start": { "type": "enum", "value": "top 85%", "enum": "TRIGGER_START", "label": "Start" },
        "toggleActions": { "type": "enum", "value": "play none none reverse", "enum": "TOGGLE_ACTIONS", "label": "Toggle actions" }
      }
    },

    {
      "id": "fade-up",
      "label": "Fade up",
      "category": "element",
      "description": "Élément translaté depuis y > 0 avec fade in. Le pattern d'entrée le plus universel.",
      "requires": ["ScrollTrigger"],
      "params": {
        "duration": { "type": "number", "value": 0.7,  "min": 0.1, "max": 2,    "step": 0.05, "unit": "s",  "label": "Durée" },
        "ease":     { "type": "enum",   "value": "power3.out", "enum": "EASE",  "label": "Ease" },
        "stagger":  { "type": "number", "value": 0.08, "min": 0,   "max": 0.3, "step": 0.01, "unit": "s",  "label": "Stagger" },
        "y":        { "type": "number", "value": 24,   "min": 0,   "max": 120, "step": 2,    "unit": "px", "label": "Distance Y", "tip": "GSAP transform alias — meilleur perf que top." },
        "useAutoAlpha": { "type": "boolean", "value": true, "label": "autoAlpha" }
      },
      "scrollTrigger": {
        "start": { "type": "enum", "value": "top 85%", "enum": "TRIGGER_START", "label": "Start" },
        "toggleActions": { "type": "enum", "value": "play none none reverse", "enum": "TOGGLE_ACTIONS", "label": "Toggle actions" }
      }
    },

    {
      "id": "fade-down",
      "label": "Fade down",
      "category": "element",
      "description": "Élément translaté depuis y < 0 avec fade in. Idéal pour menus, headers.",
      "requires": ["ScrollTrigger"],
      "params": {
        "duration": { "type": "number", "value": 0.7,  "min": 0.1, "max": 2,    "step": 0.05, "unit": "s",  "label": "Durée" },
        "ease":     { "type": "enum",   "value": "power3.out", "enum": "EASE",  "label": "Ease" },
        "stagger":  { "type": "number", "value": 0.08, "min": 0,   "max": 0.3, "step": 0.01, "unit": "s",  "label": "Stagger" },
        "y":        { "type": "number", "value": 24,   "min": 0,   "max": 120, "step": 2,    "unit": "px", "label": "Distance Y" },
        "useAutoAlpha": { "type": "boolean", "value": true, "label": "autoAlpha" }
      },
      "scrollTrigger": {
        "start": { "type": "enum", "value": "top 85%", "enum": "TRIGGER_START", "label": "Start" },
        "toggleActions": { "type": "enum", "value": "play none none reverse", "enum": "TOGGLE_ACTIONS", "label": "Toggle actions" }
      }
    },

    {
      "id": "fade-left",
      "label": "Fade left",
      "category": "element",
      "description": "Slide horizontal depuis la gauche avec fade in.",
      "requires": ["ScrollTrigger"],
      "params": {
        "duration": { "type": "number", "value": 0.7,  "min": 0.1, "max": 2,    "step": 0.05, "unit": "s",  "label": "Durée" },
        "ease":     { "type": "enum",   "value": "power3.out", "enum": "EASE",  "label": "Ease" },
        "stagger":  { "type": "number", "value": 0.08, "min": 0,   "max": 0.3, "step": 0.01, "unit": "s",  "label": "Stagger" },
        "x":        { "type": "number", "value": 32,   "min": 0,   "max": 200, "step": 4,    "unit": "px", "label": "Distance X" },
        "useAutoAlpha": { "type": "boolean", "value": true, "label": "autoAlpha" }
      },
      "scrollTrigger": {
        "start": { "type": "enum", "value": "top 85%", "enum": "TRIGGER_START", "label": "Start" },
        "toggleActions": { "type": "enum", "value": "play none none reverse", "enum": "TOGGLE_ACTIONS", "label": "Toggle actions" }
      }
    },

    {
      "id": "fade-right",
      "label": "Fade right",
      "category": "element",
      "description": "Slide horizontal depuis la droite avec fade in.",
      "requires": ["ScrollTrigger"],
      "params": {
        "duration": { "type": "number", "value": 0.7,  "min": 0.1, "max": 2,    "step": 0.05, "unit": "s",  "label": "Durée" },
        "ease":     { "type": "enum",   "value": "power3.out", "enum": "EASE",  "label": "Ease" },
        "stagger":  { "type": "number", "value": 0.08, "min": 0,   "max": 0.3, "step": 0.01, "unit": "s",  "label": "Stagger" },
        "x":        { "type": "number", "value": 32,   "min": 0,   "max": 200, "step": 4,    "unit": "px", "label": "Distance X" },
        "useAutoAlpha": { "type": "boolean", "value": true, "label": "autoAlpha" }
      },
      "scrollTrigger": {
        "start": { "type": "enum", "value": "top 85%", "enum": "TRIGGER_START", "label": "Start" },
        "toggleActions": { "type": "enum", "value": "play none none reverse", "enum": "TOGGLE_ACTIONS", "label": "Toggle actions" }
      }
    },

    {
      "id": "scale-in",
      "label": "Scale in",
      "category": "element",
      "description": "Apparition avec léger zoom + fade. Parfait pour images, cards.",
      "requires": ["ScrollTrigger"],
      "params": {
        "duration":   { "type": "number", "value": 0.7, "min": 0.1, "max": 2,    "step": 0.05, "unit": "s",  "label": "Durée" },
        "ease":       { "type": "enum",   "value": "back.out(1.7)", "enum": "EASE",  "label": "Ease" },
        "stagger":    { "type": "number", "value": 0.08, "min": 0,   "max": 0.3, "step": 0.01, "unit": "s",  "label": "Stagger" },
        "scaleFrom":  { "type": "number", "value": 0.92, "min": 0.5, "max": 1,   "step": 0.01, "unit": "",   "label": "Scale de départ", "tip": "1 = pas de zoom. 0.92 = subtil. 0.7 = dramatique." },
        "useAutoAlpha": { "type": "boolean", "value": true, "label": "autoAlpha" }
      },
      "scrollTrigger": {
        "start": { "type": "enum", "value": "top 85%", "enum": "TRIGGER_START", "label": "Start" },
        "toggleActions": { "type": "enum", "value": "play none none reverse", "enum": "TOGGLE_ACTIONS", "label": "Toggle actions" }
      }
    },

    {
      "id": "blur-in",
      "label": "Blur in",
      "category": "element",
      "description": "Apparition avec flou décroissant + fade. Effet premium.",
      "requires": ["ScrollTrigger"],
      "params": {
        "duration":  { "type": "number", "value": 0.85, "min": 0.2, "max": 2.5, "step": 0.05, "unit": "s",  "label": "Durée" },
        "ease":      { "type": "enum",   "value": "power3.out", "enum": "EASE",  "label": "Ease" },
        "stagger":   { "type": "number", "value": 0.08, "min": 0,   "max": 0.3, "step": 0.01, "unit": "s",  "label": "Stagger" },
        "blurFrom":  { "type": "number", "value": 20,   "min": 0,   "max": 50,  "step": 1,    "unit": "px", "label": "Flou de départ" },
        "useAutoAlpha": { "type": "boolean", "value": true, "label": "autoAlpha" }
      },
      "scrollTrigger": {
        "start": { "type": "enum", "value": "top 85%", "enum": "TRIGGER_START", "label": "Start" },
        "toggleActions": { "type": "enum", "value": "play none none reverse", "enum": "TOGGLE_ACTIONS", "label": "Toggle actions" }
      }
    },

    {
      "id": "mask-reveal",
      "label": "Mask reveal",
