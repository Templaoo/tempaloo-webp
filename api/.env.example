NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Postgres (Neon). Full URL including sslmode=require.
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# Image conversion
MAX_IMAGE_BYTES=26214400
DEFAULT_QUALITY=82

# Freemius — from Developer Dashboard → your product → Settings → Keys + API & Keys
FREEMIUS_PRODUCT_ID=
FREEMIUS_PUBLIC_KEY=pk_...
FREEMIUS_SECRET_KEY=sk_...
FREEMIUS_API_KEY=             # Bearer token from the API & Keys tab

# Server-to-server auth for /v1/account/* endpoints (shared with Next.js)
INTERNAL_API_KEY=change-me-to-a-long-random-string

# Monitoring (optional)
SENTRY_DSN=
