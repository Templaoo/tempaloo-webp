# Tempaloo WebP API — environment variables
# Copy to .env locally; in production these go in the Render dashboard.

# ─── Runtime ──────────────────────────────────────────────────────────
NODE_ENV=production              # production | development | test
PORT=3000                        # Render injects its own PORT — leave 3000 in dev only
LOG_LEVEL=info                   # trace | debug | info | warn | error

# ─── Database (Neon) ──────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# Use the POOLED connection string (ep-xxx-pooler.*) for serverless-friendly limits.
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ─── Conversion ───────────────────────────────────────────────────────
MAX_IMAGE_BYTES=26214400         # 25 MB hard limit (validated 2026-04-24)
DEFAULT_QUALITY=82               # WebP/AVIF default quality (1-100)

# ─── Freemius ─────────────────────────────────────────────────────────
FREEMIUS_PRODUCT_ID=28337
FREEMIUS_PUBLIC_KEY=pk_xxx       # safe to expose
FREEMIUS_SECRET_KEY=sk_xxx       # webhook signature verification — KEEP SECRET
FREEMIUS_API_KEY=xxx             # Bearer token for Freemius API calls — KEEP SECRET

# ─── Web ↔ API auth ───────────────────────────────────────────────────
# Shared secret between this API and the Next.js web app (Vercel).
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=change-me-min-16-chars

# ─── Unlimited soft cap watcher (cron) ────────────────────────────────
UNLIMITED_FAIR_USE=500000        # threshold/month per Unlimited license
UNLIMITED_NOTIFY_WEBHOOK=        # optional Slack/Discord webhook for internal alerts

# ─── Sentry (optional) ────────────────────────────────────────────────
SENTRY_DSN=
