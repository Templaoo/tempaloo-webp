# LocalWP MySQL credentials for the dev-reset script.
# Copy to `.env.reset` (gitignored) and fill in values from:
#   LocalWP → your site → Database tab → "Open DB tool" shows host/port/user/pass.
#
# The reset script also reads DATABASE_URL from api/.env (already there for the
# API), so you don't need to duplicate it here.

WP_DB_HOST=127.0.0.1
WP_DB_PORT=10003
WP_DB_USER=root
WP_DB_PASSWORD=root
WP_DB_NAME=local
WP_TABLE_PREFIX=wp_
