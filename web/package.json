{
  "name": "@tempaloo/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:fresh": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@freemius/checkout": "^1.4.1",
    "@neondatabase/auth": "^0.2.0-beta.1",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "next": "^16.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.59.0"
  }
}
