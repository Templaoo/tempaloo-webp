# Backend API
TEMPALOO_API_BASE=http://localhost:3000/v1
TEMPALOO_INTERNAL_KEY=change-me-to-a-long-random-string

# Neon Auth (Better Auth)
# NEON_AUTH_BASE_URL from Neon Console → Project → Auth → Configuration
# NEON_AUTH_COOKIE_SECRET: openssl rand -base64 32   (or node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=
